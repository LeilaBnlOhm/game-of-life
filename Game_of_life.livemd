## Module Controller

This module Life.Controller controls the execution flow of the simulation and coordinates timing and updates.

```elixir
defmodule Life.Controller do
  use GenServer

  @interval 300

  def start_link(_) do
    GenServer.start_link(
      __MODULE__,
      %{running: false, subscribers: MapSet.new()},
      name: __MODULE__
    )
  end

  def start, do: GenServer.cast(__MODULE__, :start)
  def stop, do: GenServer.cast(__MODULE__, :stop)
  def step, do: GenServer.cast(__MODULE__, :step)
  def subscribe(pid), do: GenServer.cast(__MODULE__, {:subscribe, pid})

  def init(state), do: {:ok, state}

  def handle_cast({:subscribe, pid}, state) do
    {:noreply, %{state | subscribers: MapSet.put(state.subscribers, pid)}}
  end

  def handle_cast(:step, state) do
    Life.Coordinator.step()
    {:noreply, state}
  end

  def handle_cast(:start, state) do
    Life.Coordinator.step()
    {:noreply, %{state | running: true}}
  end

  def handle_cast(:stop, state) do
    {:noreply, %{state | running: false}}
  end

  def handle_info(:generation_complete, %{running: true} = state) do
    notify(state.subscribers)
    Process.send_after(self(), :tick, @interval)
    {:noreply, state}
  end

  def handle_info(:generation_complete, state) do
    notify(state.subscribers)
    {:noreply, state}
  end

  def handle_info(:tick, %{running: true} = state) do
    Life.Coordinator.step()
    {:noreply, state}
  end

  def handle_info(:tick, state), do: {:noreply, state}

  defp notify(subscribers) do
    Enum.each(subscribers, fn pid ->
      send(pid, :update_display)
    end)
  end
end
```

