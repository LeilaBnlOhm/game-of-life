## Module Coordinator

The module Life.Coordinator is responsible for creating all cell processes and orchestrating their synchronization, ensuring that each generation of the simulation evolves in a consistent and coordinated manner.

```elixir
defmodule Life.Coordinator do
  use GenServer

  @size 30
  @worker :"worker@127.0.0.1"

  def start_link(_) do
    GenServer.start_link(__MODULE__, %{}, name: __MODULE__)
  end

  def step, do: GenServer.cast(__MODULE__, :step)
  def grid, do: GenServer.call(__MODULE__, :grid)
  def get_cells, do: GenServer.call(__MODULE__, :get_cells)

  # DEBUG / preuve distribution
  def pids, do: GenServer.call(__MODULE__, :pids)

  def init(_) do
    master = Node.self()
    worker = @worker

    # 1) Vérifier que le worker répond
    unless :net_adm.ping(worker) == :pong do
      raise "Worker node not reachable: #{inspect(worker)}. Start it with: iex --name worker@127.0.0.1 --cookie life"
    end

    # 2) Vérifier que Life.Cell est chargé sur le worker
    case :rpc.call(worker, Code, :ensure_loaded?, [Life.Cell]) do
      true -> :ok
      false -> raise "Life.Cell is not loaded on worker. Load it on the worker before starting coordinator."
      other -> raise "Could not verify Life.Cell on worker: #{inspect(other)}"
    end

    # 3) Créer les cellules : moitié haute sur master, moitié basse sur worker
    cells =
      for x <- 0..(@size - 1), y <- 0..(@size - 1) do
        target = if y < div(@size, 2), do: master, else: worker
    
        result =
          if target == master do
            Life.Cell.start_link(x: x, y: y, alive: Enum.random([0, 1]), coordinator: self())
          else
            :rpc.call(worker, Life.Cell, :start, [[
              x: x, y: y, alive: Enum.random([0, 1]),
              coordinator: self()
            ]])
          end
    
        {:ok, pid} =
          case result do
            {:ok, pid} -> {:ok, pid}
            other -> raise "Failed to start cell at (#{x},#{y}) on #{inspect(target)}: #{inspect(other)}"
          end
    
        {{x, y}, pid}
      end
      |> Map.new()


    # 4) Configurer les voisins (cast OK sur pid local/distant)
    Enum.each(cells, fn {{x, y}, pid} ->
      neighbors = get_neighbor_pids(cells, x, y)
      Life.Cell.set_neighbors(pid, neighbors)
    end)

    {:ok, %{cells: cells, ready_cells: MapSet.new(), total_cells: map_size(cells)}}
  end

  defp get_neighbor_pids(cells, x, y) do
    for dx <- -1..1,
        dy <- -1..1,
        {dx, dy} != {0, 0} do
      Map.get(cells, {x + dx, y + dy})
    end
    |> Enum.filter(& &1)
  end

  def handle_cast(:step, state) do
    state = %{state | ready_cells: MapSet.new()}

    Enum.each(state.cells, fn {_pos, pid} ->
      Life.Cell.request_neighbors(pid)
    end)

    {:noreply, state}
  end

  def handle_info({:cell_ready, pid, _next_state}, state) do
    ready_cells = MapSet.put(state.ready_cells, pid)

    if MapSet.size(ready_cells) == state.total_cells do
      Enum.each(state.cells, fn {_pos, pid} ->
        Life.Cell.apply_next(pid)
      end)

      send_update()
    end

    {:noreply, %{state | ready_cells: ready_cells}}
  end

  def handle_call(:grid, _from, state) do
    grid =
      state.cells
      |> Enum.map(fn {_pos, pid} -> Life.Cell.get_state(pid) end)
      |> Enum.map(fn {x, y, alive} -> {{x, y}, alive} end)
      |> Map.new()

    {:reply, grid, state}
  end

  def handle_call(:get_cells, _from, state) do
    {:reply, map_size(state.cells), state}
  end

  def handle_call(:pids, _from, state) do
    {:reply, state.cells, state}
  end

  defp send_update do
    case Process.whereis(Life.Controller) do
      nil -> :ok
      pid -> send(pid, :generation_complete)
    end
  end
end

```

