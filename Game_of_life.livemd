# A distributed simulation of the Conway's Game of Life

```elixir
Mix.install([
  {:kino, "~> 0.12"}
])
```

## Cell Module

The Life.Cell module models each cell as an autonomous GenServer that exchanges messages with its neighbours and computes its next state locally before synchronizing with the coordinator.

```elixir
defmodule Life.Cell do
  use GenServer

  def start_link(opts) do
    GenServer.start_link(__MODULE__, opts)
  end

  def start(opts) do
    GenServer.start(__MODULE__, opts)
  end

  def set_neighbors(pid, neighbors), do: GenServer.cast(pid, {:set_neighbors, neighbors})
  def get_state(pid), do: GenServer.call(pid, :get_state)
  def request_neighbors(pid), do: GenServer.cast(pid, :request_neighbors)
  def apply_next(pid), do: GenServer.cast(pid, :apply_next)

  def init(opts) do
    {:ok,
     %{
       x: opts[:x],
       y: opts[:y],
       alive: opts[:alive],
       neighbors: [],
       neighbor_count: 0,
       responses_received: 0,
       next_state: nil,
       coordinator: opts[:coordinator]
     }}
  end

  def handle_cast({:set_neighbors, neighbors}, state) do
    {:noreply, %{state | neighbors: neighbors}}
  end

  def handle_cast(:request_neighbors, state) do
    Enum.each(state.neighbors, fn neighbor_pid ->
      send(neighbor_pid, {:state_request, self()})
    end)

    {:noreply, %{state | neighbor_count: 0, responses_received: 0}}
  end

  def handle_cast({:neighbor_state, alive_state}, state) do
    new_count = state.neighbor_count + if alive_state == 1, do: 1, else: 0
    new_responses = state.responses_received + 1

    state = %{state | neighbor_count: new_count, responses_received: new_responses}

    if new_responses == length(state.neighbors) do
      next = compute_next_state(state.alive, state.neighbor_count)
      send(state.coordinator, {:cell_ready, self(), next})
      {:noreply, %{state | next_state: next}}
    else
      {:noreply, state}
    end
  end

  def handle_cast(:apply_next, state) do
    {:noreply, %{state | alive: state.next_state}}
  end

  def handle_info({:state_request, from_pid}, state) do
    send(from_pid, {:neighbor_state, state.alive})
    {:noreply, state}
  end

  def handle_info({:neighbor_state, alive_state}, state) do
    handle_cast({:neighbor_state, alive_state}, state)
  end

  def handle_call(:get_state, _from, state) do
    {:reply, {state.x, state.y, state.alive}, state}
  end

  defp compute_next_state(alive, neighbor_count) do
    case {alive, neighbor_count} do
      {1, 2} -> 1
      {1, 3} -> 1
      {0, 3} -> 1
      _ -> 0
    end
  end
end

```

