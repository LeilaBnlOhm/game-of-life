```

## Interactive Interface and Visualization

This section uses Kino to display the grid and control the simulation, updating the view after each generation.

````elixir
frame = Kino.Frame.new()
Kino.render(frame)

step_btn = Kino.Control.button("Step")
start_btn = Kino.Control.button("Start")
stop_btn = Kino.Control.button("Stop")

Kino.render(Kino.Layout.grid([step_btn, start_btn, stop_btn], columns: 3))

render = fn ->
  grid = Life.Coordinator.grid()

  text =
    grid
    |> Life.Display.as_table()
    |> Enum.map(&Enum.join(&1, " "))
    |> Enum.join("\n")

  Kino.Frame.render(frame, Kino.Markdown.new("```\n#{text}\n```"))
end

render.()

spawn(fn ->
  Life.Controller.subscribe(self())

  receive_loop = fn receive_loop ->
    receive do
      :update_display ->
        render.()
        receive_loop.(receive_loop)
    end
  end

  receive_loop.(receive_loop)
end)

Kino.listen(step_btn, fn _ ->
  Life.Controller.step()
end)

Kino.listen(start_btn, fn _ ->
  Life.Controller.start()
end)

Kino.listen(stop_btn, fn _ ->
  Life.Controller.stop()
end)

:ok
````

